
# =========================
# 共通: 一時ファイル / キャッシュ
# =========================
*.log
*.tmp
*.bak
*.swp
*.pyc
*.pyo
*.class
__pycache__/
.venv/
.codex-tmp/

# =========================
# 研究データ: 外部管理対象
# =========================
QGIS/
SSD/
既往研究PDF/
整備データ/

# =========================
# 生成物: 再生成可能な出力は追跡しない
# =========================
data/output/LST/**/*.tif
data/output/LST/**/*.aux.xml
data/output/maps/**/*.tif
data/output/maps/**/*.aux.xml
data/output/gis_wgs84/*.gpkg

# 入力の大容量ラスタを追跡しない
data/input/**/*.tif

# GIS補助ファイル
*.aux
*.aux.xml

# PDFは原則追跡しない（文献はメタデータで管理）
*.pdf

# QGISプロジェクトファイル
*.qgz

# =========================
# 例外: 共有用サンプルは追跡可
# =========================
!data/samples/
!data/samples/**
